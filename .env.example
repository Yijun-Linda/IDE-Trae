# AI认知翻译官 - 环境变量示例
# 复制此文件为 .env 并填入真实值
# 注意: .env 文件不应提交到Git仓库

# ============================================
# 大模型API配置 (通义千问/豆包)
# ============================================

# 通义千问API Key
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-turbo

# 豆包API Key (备选)
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-lite

# ============================================
# 云打印机API配置
# ============================================

# 易联云配置
YILIANYUN_APP_ID=your_yly_app_id
YILIANYUN_APP_SECRET=your_yly_app_secret
YILIANYUN_MACHINE_CODE=your_printer_machine_code
YILIANYUN_API_URL=https://open-api.10ss.net/

# 飞鹅云配置 (备选)
FEIE_USER=your_feie_user
FEIE_UKEY=your_feie_ukey
FEIE_SN=your_printer_sn
FEIE_API_URL=https://api.feieyun.com/

# 默认使用的打印机厂商 (yilianyun/feie)
PRINTER_PROVIDER=yilianyun

# ============================================
# Webhook配置
# ============================================

# Webhook签名验证密钥
WEBHOOK_SECRET=your_webhook_secret_here

# 服务器端口
PORT=5000

# ============================================
# 业务配置
# ============================================

# 每杯制作间隔时间（分钟）
DELAY_MINUTES=5

# 最大队列长度
MAX_QUEUE_SIZE=20

# 打印失败重试次数
RETRY_TIMES=3

# 环境 (development/production)
ENVIRONMENT=development

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 是否记录详细API调用日志
VERBOSE_LOGGING=false
